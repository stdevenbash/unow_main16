<odoo>
    <record id="hr_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.projects</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_open_employee_projects"
                        icon="fa-folder-open"
                        attrs="{'invisible': [('total_projects', '=', 0)]}">
                    <field name="total_projects" widget="statinfo" string="Projects"/>
                </button>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Projects">
                    <group>
                        <field name="total_projects" readonly="1"/>
                    </group>
                    <group>
                        <field name="project_ids" widget="one2many_list" mode="tree,form">
                            <tree>
                                <field name="name"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </group>
                            </form>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
